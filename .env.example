# ============================================================
# Environment variables template
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` to a public repository.
# ============================================================

# --- Lovable Cloud / Supabase (frontend, publishable) ---
# These values are safe to expose in the browser bundle (they are
# publishable/anon keys protected by Row Level Security). They are
# still kept out of the repo so each fork uses its own backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Optional: override the stock-data API base URL ---
# Leave empty to default to the Supabase Edge Function of the
# project referenced above.
VITE_STOCK_API_URL=

# ============================================================
# Server-side secrets (NEVER put these here or in any .env file)
# ============================================================
# The following keys live ONLY as Supabase Edge Function secrets,
# configured in the Supabase dashboard. They are never read by the
# frontend and never bundled into the client:
#
#   FINNHUB_API_KEY
#   ALPHA_VANTAGE_API_KEY
#   TWELVE_DATA_API_KEY
#   MASSIVE_API_KEY_1 / _2 / _3
#   SIMFIN_API_KEY
#   EULERPOOL_API_KEY
#   FRED_API_KEY
#   WORLD_NEWS_API_KEY
#   LOVABLE_API_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#
# To run this project against your own backend, create your own
# Supabase project, deploy the edge functions from `supabase/functions/`,
# and set the secrets above in the Supabase dashboard.
